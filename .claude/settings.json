      "Bash(gh run view:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr comment:*)",
      "Bash(git push origin claude/)",
      "Bash(git push -u origin claude/)",
      "Bash(git add:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git grep:*)",
      "Bash(git init:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(obsidian:*)",
      "Bash(osascript -e:*)",
      "Bash(pwd:*)",
      "Bash(rg:*)",
      "Bash(sed -n:*)",
      "Bash(sort:*)",
      "Bash(stat:*)",
      "Bash(tail:*)",
      "Bash(tr:*)",
      "Bash(type:*)",
      "Bash(uname:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(codex:*)",
      "Bash(whoami:*)",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "Read(**)",
      "Write(.tmp/**)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec*)",
      "Bash(find * -execdir*)",
      "Bash(find * -iwholename*/*)",
      "Bash(find * -ok*)",
      "Bash(find *|*xargs *)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git clean:*)",
      "Bash(git merge:*)",
      "Bash(git push:* --force*)",
      "Bash(git push:* -f*)",
      "Bash(git push:* --force-with-lease*)", // 必要なら外す
      "Bash(git push:* --delete*)",
      "Bash(git push:* :*)", // refspec での削除
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git push origin HEAD*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git revert:*)",
      "Bash(git stash:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(git switch:*)",
      "Bash(perl -pi:*)",
      "Bash(rm -rf:*)",
      "Bash(sed -i:*)",
      "Bash(sudo:*)",
      "Bash(tee:*)",
      "Bash(wget:*)",
      "Bash(xargs:*)",
      "Read(.env*)",
      "Bash(cat *.env*)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Write(.env*)"
    ]
  },
  "showThinkingSummaries": true
}
