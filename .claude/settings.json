{
  "enableAllProjectMcpServers": true,
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(cut:*)",
      "Bash(date:*)",
      "Bash(eza:*)",
      "Bash(file:*)",
